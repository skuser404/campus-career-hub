# ─────────────────────────────────────────────────────────────
# Campus Career Hub — environment template
#
# Copy to `.env` and fill in real values. `.env` is gitignored.
# The API validates every one of these at boot with Zod and
# REFUSES TO START if a required value is missing or malformed.
# ─────────────────────────────────────────────────────────────

# ── Runtime ──────────────────────────────────────────────────
NODE_ENV=development
PORT=4000
LOG_LEVEL=debug

# ── Database ─────────────────────────────────────────────────
# Render / Neon / Supabase connection string.
DATABASE_URL=postgresql://user:password@host:5432/campus_career_hub?sslmode=require

# ── Auth ─────────────────────────────────────────────────────
# Generate each with:  node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
# MUST be at least 32 characters. MUST be different from each other.
JWT_ACCESS_SECRET=replace-me-with-a-long-random-string-min-32-chars
JWT_REFRESH_SECRET=replace-me-with-a-different-long-random-string-32
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d
BCRYPT_ROUNDS=12

# Cookie domain. Leave blank for localhost; set to your apex domain in production.
COOKIE_DOMAIN=

# ── CORS ─────────────────────────────────────────────────────
# Comma-separated allowlist. No wildcards — credentials are sent.
CORS_ORIGINS=http://localhost:3000

# ── Cloudinary (image uploads) ───────────────────────────────
# Optional in development: if unset, the admin UI falls back to
# pasting an image URL directly and upload endpoints return 503.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_UPLOAD_FOLDER=campus-career-hub

# ── Google Sign-In (optional) ────────────────────────────────
# The OAuth Client ID from Google Cloud Console (Web application). Same value as
# NEXT_PUBLIC_GOOGLE_CLIENT_ID below. Unset → Google endpoint returns 503 and the
# button is hidden; password login is unaffected.
GOOGLE_CLIENT_ID=

# ── Seed (first admin account) ───────────────────────────────
SEED_ADMIN_EMAIL=admin@jainuniversity.ac.in
SEED_ADMIN_PASSWORD=ChangeMe!2024
SEED_ADMIN_NAME=Placement Office

# ─────────────────────────────────────────────────────────────
# Frontend (apps/web). NEXT_PUBLIC_* is exposed to the browser —
# never put a secret behind this prefix.
# ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:4000/api/v1
NEXT_PUBLIC_APP_NAME=Campus Career Hub

# Google Sign-In (students). The Client ID from Google Cloud Console → Credentials
# → OAuth client ID (Web application). NOT a secret — it ships in the browser.
# Set the SAME value as GOOGLE_CLIENT_ID on the API. Leave blank to hide the
# Google button and use password login only.
NEXT_PUBLIC_GOOGLE_CLIENT_ID=
