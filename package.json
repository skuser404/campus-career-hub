{
  "name": "campus-career-hub",
  "version": "1.0.0",
  "private": true,
  "description": "Centralized platform for placement, internship, hackathon, certification and event opportunities.",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "npm run build -w @cch/shared && npm run build -w @cch/api && npm run build -w @cch/web",
    "dev": "npm-run-all --parallel dev:api dev:web",
    "dev:api": "npm run dev -w @cch/api",
    "dev:web": "npm run dev -w @cch/web",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "db:generate": "npm run db:generate -w @cch/api",
    "db:migrate": "npm run db:migrate -w @cch/api",
    "db:seed": "npm run db:seed -w @cch/api",
    "db:studio": "npm run db:studio -w @cch/api",
    "verify": "npm run typecheck && npm run lint && npm run build"
  },
  "devDependencies": {
    "npm-run-all": "^4.1.5",
    "typescript": "^5.7.3"
  }
}
